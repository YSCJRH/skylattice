{
  "name": "skylattice-workspaces",
  "private": true,
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "web:lint": "npm run lint --workspace apps/web",
    "web:preview": "python tools/run_web_preview.py dev",
    "web:preview:build": "python tools/run_web_preview.py build",
    "web:preview:start": "python tools/run_web_preview.py start",
    "web:preview:check": "python tools/check_web_preview_state.py",
    "web:hosted-alpha:check": "node tools/check_hosted_alpha_setup.mjs",
    "web:hosted-alpha:bootstrap": "node tools/bootstrap_hosted_alpha_db.mjs"
  }
}
