# Skylattice Hosted Alpha example env
# Copy into a local `.env.local` for development, or configure the same values in Vercel.

# Public app URL for the hosted control plane.
NEXT_PUBLIC_SKYLATTICE_APP_URL=https://your-skylattice-app.vercel.app
NEXTAUTH_URL=https://your-skylattice-app.vercel.app

# Canonical public docs site.
NEXT_PUBLIC_SKYLATTICE_DOCS_URL=https://yscjrh.github.io/skylattice/

# Hosted Alpha deployments should set this to force production semantics.
SKYLATTICE_HOSTED_ALPHA=1

# GitHub OAuth for browser sign-in.
GITHUB_ID=
GITHUB_SECRET=
NEXTAUTH_SECRET=

# Control-plane persistence.
# Use Neon/Postgres in Hosted Alpha. Local-file persistence is for development only.
DATABASE_URL=
# SKYLATTICE_CONTROL_PLANE_DATABASE_URL=

# Local development only:
# SKYLATTICE_CONTROL_PLANE_STATE_PATH=../../.local/state/web-control-plane.json
# NEXT_PUBLIC_SKYLATTICE_DEMO_PREVIEW=1
# SKYLATTICE_DEMO_PREVIEW=1
